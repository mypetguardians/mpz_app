# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=
DJANGO_ENV_NAME=

# JWT signing key (Supabase 프로젝트의 JWT secret과 동일해야 강아지학교 PostgREST가
# 같은 토큰을 검증할 수 있음. Supabase Studio → Settings → API → JWT Settings에서 복사.
# 미설정 시 DJANGO_SECRET_KEY로 fallback — 통합 전 호환용)
SUPABASE_JWT_SECRET=

# Database (Supabase)
DATABASE_URL=
CONN_MAX_AGE=

# Redis
REDIS_URL=

# CORS / Session
# 콤마로 분리. 강아지학교(school.mpz.kr / dev-school.mpz.kr) 도메인이 카카오 콜백 후
# 리다이렉트 화이트리스트(user/kakao_api.py)와 CORS 허용 출처에도 함께 사용된다.
# 예시: https://mpz.kr,https://dev.mpz.kr,https://school.mpz.kr,https://dev-school.mpz.kr
CORS_ALLOWED_ORIGINS=
SESSION_COOKIE_SAMESITE=
SESSION_COOKIE_DOMAIN=.mpz.kr
FRONTEND_URL=

# Kakao OAuth
KAKAO_SOCIAL_LOGIN_CLIENT_ID=
KAKAO_SOCIAL_LOGIN_CLIENT_SECRET=

# Supabase Storage (dev)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_PUBLIC_BASE_URL=

# Cloudflare R2 Storage (prod)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_ACCOUNT_ID=
R2_PUBLIC_BASE_URL=

# Firebase FCM
FCM_PROJECT_ID=
FIREBASE_ADMIN_CREDENTIALS_JSON=

# Public Data API
PUBLIC_DATA_SERVICE_KEY=
SYNC_API_KEY=

# SMS
SMS_API_KEY=

# Email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# AI (미수령)
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=
LANGCHAIN_PROJECT=
LANGCHAIN_TRACING_V2=

# Frontend (BE에서 참조)
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=
