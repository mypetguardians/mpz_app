# Python 버전 (기본값: 3.12-slim-bullseye)
ARG PYTHON_VERSION=3.12-slim-bullseye
FROM python:${PYTHON_VERSION}

# 가상환경 생성
RUN python -m venv /opt/venv
ENV PATH=/opt/venv/bin:$PATH
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1

# OS deps 설치 + pip 업그레이드 + requirements 설치 (캐시 최적화)
COPY backend/requirements.txt /tmp/requirements.txt
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    libjpeg-dev \
    libcairo2 \
    gcc \
    && pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r /tmp/requirements.txt \
    && rm -rf /var/lib/apt/lists/*

# 코드 복사
WORKDIR /code
COPY ./backend /code

# Django 환경 변수 (런타임에 주입)
ENV DJANGO_DEBUG=0

# 실행 스크립트 생성 (collectstatic 이동)
ARG PROJ_NAME="cfehome"
RUN echo '#!/bin/bash' > ./paracord_runner.sh \
    && echo 'RUN_PORT="${PORT:-8000}"' >> ./paracord_runner.sh \
    && echo 'python manage.py migrate --no-input' >> ./paracord_runner.sh \
    && echo 'python manage.py collectstatic --noinput' >> ./paracord_runner.sh \
    && echo "gunicorn ${PROJ_NAME}.asgi:application -k uvicorn.workers.UvicornWorker --workers 4 --bind 0.0.0.0:\$RUN_PORT" >> ./paracord_runner.sh \
    && chmod +x paracord_runner.sh

CMD ["./paracord_runner.sh"]